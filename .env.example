# =============================================================================
# tw-stock-collector 環境變數樣板
# 使用方式：cp .env.example .env，填入你的值
# =============================================================================

# FinMind API Token（必填）
FINMIND_TOKEN=

# Postgres 連線
# 開發本機：postgresql://twstock:twstock@localhost:5432/twstock
# 容器內互連：postgresql://twstock:twstock@postgres:5432/twstock
DATABASE_URL=postgresql://twstock:twstock@localhost:5432/twstock

# 日誌等級（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
